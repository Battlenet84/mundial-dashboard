API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026
DB_PATH=data/mundial.db

# Odds-API.io

# Get a free key from https://odds-api.io/
ODDS_API_IO_KEY=put_your_key_here
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3

# API quota protection

API_DAILY_LIMIT=100
API_PER_MINUTE_LIMIT=10
API_MIN_SECONDS_BETWEEN_REQUESTS=7
USE_API_CACHE=true

# API profile support

API_FOOTBALL_PROFILE=default

# Optional multi-key support.

# Leave empty if using only API_FOOTBALL_KEY.

# Example:

# API_FOOTBALL_KEYS_JSON={"default":"your_default_key_here","backup":"your_backup_key_here"}

API_FOOTBALL_KEYS_JSON=

# Optional ledger path.

# If empty, the app should automatically use:

# data/api_request_ledger_default.json for API_FOOTBALL_PROFILE=default

API_REQUEST_LEDGER_PATH=

# StatsHub snapshot evaluation

STATSHUB_ENABLED=false
STATSHUB_BASE_URL=https://www.statshub.com
STATSHUB_MIN_SECONDS_BETWEEN_REQUESTS=10
STATSHUB_CACHE_ENABLED=true
STATSHUB_MAX_REQUESTS_PER_RUN=5
STATSHUB_SNAPSHOT_MODE=true
